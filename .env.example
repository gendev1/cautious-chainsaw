# Wealth Advisor POC - Environment Configuration
# Copy this to .env and fill in your values

# ---- LLM Provider Configuration ----
# Set these based on which provider you're using:

# Together AI (default)
LLM_BASE_URL=https://api.together.xyz/v1
LLM_MODEL=zai-org/GLM-5
LLM_API_KEY=your-together-api-key

# Z.ai Direct
# LLM_BASE_URL=https://api.z.ai/api/paas/v4
# LLM_MODEL=glm-5
# LLM_API_KEY=your-zai-api-key

# OpenRouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=z-ai/glm-5
# LLM_API_KEY=your-openrouter-key

# OpenAI (if you want to use GPT instead)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=your-openai-key

# NVIDIA
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=z-ai/glm5
# LLM_API_KEY=your-nvidia-key

# ---- Database ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=wealth_advisor

# ---- Cache ----
REDIS_URL=redis://localhost:6379

# ---- Server ----
PORT=8080
SIDECAR_PORT=8081
SIDECAR_URL=http://localhost:8081

# ---- Multi-Tenancy ----
BASE_DOMAIN=wealthadvisor.com
TENANT_CACHE_TTL=300

# ---- Sidecar ↔ Go Internal Communication ----
SIDECAR_SECRET=your-shared-secret-here
GO_INTERNAL_URL=http://localhost:8080
