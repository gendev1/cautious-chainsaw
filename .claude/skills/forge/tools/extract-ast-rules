#!/usr/bin/env bash
set -euo pipefail

# extract-ast-rules: Parse ast-grep rules from exploration.md
#
# Usage:
#   extract-ast-rules <exploration.md>
#
# Extracts all ast-grep rules from YAML code blocks under ## Structural Patterns,
# along with their section name and annotations ([insufficient-sample], [grep-fallback]).
#
# Output: JSON array of rules:
#   [
#     {
#       "name": "Error Handling",
#       "rule": "yaml content...",
#       "insufficient_sample": false,
#       "grep_fallback": false,
#       "sample_count": null
#     }
#   ]
#
# Exit codes:
#   0 — rules extracted
#   1 — no rules found or file missing

FILE="${1:?Usage: extract-ast-rules <exploration.md>}"

if [[ ! -f "$FILE" ]]; then
  echo "error: $FILE not found" >&2
  exit 1
fi

python3 -c "
import re, json, sys

content = open('$FILE').read()

# Find Structural Patterns section
match = re.search(r'## Structural Patterns.*?\n(.*?)(\n## (?!#)|\Z)', content, re.DOTALL)
if not match:
    print('error: no ## Structural Patterns section found', file=sys.stderr)
    sys.exit(1)

section = match.group(1)

rules = []

# Split by ### subsections
subsections = re.split(r'### ', section)
for sub in subsections[1:]:  # skip first empty
    lines = sub.strip().split('\n')
    name = lines[0].strip()

    full_text = '\n'.join(lines[1:])

    # Check annotations
    insufficient = bool(re.search(r'\[insufficient-sample(?::\s*(\d+)\s*match(?:es)?)?\]', full_text))
    sample_count = None
    sample_match = re.search(r'\[insufficient-sample:\s*(\d+)', full_text)
    if sample_match:
        sample_count = int(sample_match.group(1))

    grep_fallback = '[grep-fallback]' in full_text

    # Extract YAML code blocks (ast-grep rules)
    yaml_blocks = re.findall(r'\x60\x60\x60ya?ml\s*\n(.*?)\x60\x60\x60', full_text, re.DOTALL)

    if yaml_blocks:
        for block in yaml_blocks:
            rules.append({
                'name': name,
                'rule': block.strip(),
                'insufficient_sample': insufficient,
                'grep_fallback': grep_fallback,
                'sample_count': sample_count
            })
    elif grep_fallback:
        # grep-based pattern, extract the grep command or pattern
        grep_patterns = re.findall(r'\x60(grep[^\x60]+)\x60', full_text)
        rules.append({
            'name': name,
            'rule': grep_patterns[0] if grep_patterns else '(no rule extracted)',
            'insufficient_sample': insufficient,
            'grep_fallback': True,
            'sample_count': sample_count
        })

if not rules:
    print('error: no ast-grep rules found', file=sys.stderr)
    sys.exit(1)

print(json.dumps(rules, indent=2))
"
