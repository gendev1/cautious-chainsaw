#!/usr/bin/env bash
set -euo pipefail

# validate-artifact: Check that a forge artifact exists and contains required sections.
#
# Usage:
#   validate-artifact <file> <section> [<section2> ...]
#   validate-artifact discovery.md "## Requirements"
#   validate-artifact exploration.md "## Structural Patterns" "## Key Files"   # OR logic
#
# Exit codes:
#   0 — file exists and contains at least one required section
#   1 — file missing or no required section found
#
# With --or flag (default): at least ONE section must be present
# With --all flag: ALL sections must be present

MODE="or"
if [[ "${1:-}" == "--all" ]]; then
  MODE="all"
  shift
fi
if [[ "${1:-}" == "--or" ]]; then
  MODE="or"
  shift
fi

FILE="${1:?Usage: validate-artifact [--all|--or] <file> <section> [<section2> ...]}"
shift

if [[ $# -eq 0 ]]; then
  echo "error: at least one section required" >&2
  exit 1
fi

if [[ ! -f "$FILE" ]]; then
  echo "missing: $FILE does not exist"
  exit 1
fi

FOUND=()
MISSING=()

for section in "$@"; do
  if grep -qF "$section" "$FILE"; then
    FOUND+=("$section")
  else
    MISSING+=("$section")
  fi
done

if [[ "$MODE" == "or" ]]; then
  if [[ ${#FOUND[@]} -gt 0 ]]; then
    echo "ok: found ${FOUND[*]}"
    exit 0
  else
    echo "fail: none of [${MISSING[*]}] found in $FILE"
    exit 1
  fi
else
  if [[ ${#MISSING[@]} -eq 0 ]]; then
    echo "ok: all sections present"
    exit 0
  else
    echo "fail: missing [${MISSING[*]}] in $FILE"
    exit 1
  fi
fi
