#!/usr/bin/env bash
set -euo pipefail

# parse-markdown-table: Extract a markdown table as structured JSON.
#
# Usage:
#   parse-markdown-table <file> <section-header>
#   parse-markdown-table implementation-context.md "## External Dependencies"
#   parse-markdown-table test-manifest.md "## Spec → Test Mapping"
#   parse-markdown-table test-manifest.md "## Test Files Created" --csv
#
# Finds the first table under the given section header and outputs JSON (default)
# or CSV. The table must have a header row and separator row (|---|).
#
# Exit codes:
#   0 — table found and parsed
#   1 — section or table not found

FILE="${1:?Usage: parse-markdown-table <file> <section-header> [--csv]}"
SECTION="${2:?Usage: parse-markdown-table <file> <section-header> [--csv]}"
FORMAT="${3:---json}"

if [[ ! -f "$FILE" ]]; then
  echo "error: $FILE not found" >&2
  exit 1
fi

python3 -c "
import re, json, csv, sys, io

content = open('$FILE').read()
section = '$SECTION'
fmt = '$FORMAT'

# Find the section
# Escape special regex chars in section header
escaped = re.escape(section)
match = re.search(escaped + r'\s*\n(.*?)(\n##|\Z)', content, re.DOTALL)
if not match:
    print(f'error: section \"{section}\" not found in $FILE', file=sys.stderr)
    sys.exit(1)

text = match.group(1)

# Find table lines
lines = [l.strip() for l in text.split('\n') if l.strip().startswith('|')]
if len(lines) < 2:
    print(f'error: no table found under \"{section}\"', file=sys.stderr)
    sys.exit(1)

# Parse header
headers = [h.strip().strip('\`') for h in lines[0].split('|')[1:-1]]

# Skip separator (line with ---)
data_start = 1
for i, line in enumerate(lines[1:], 1):
    if re.match(r'\|[\s\-:|]+\|', line):
        data_start = i + 1
        break

# Parse rows
rows = []
for line in lines[data_start:]:
    cells = [c.strip().strip('\`') for c in line.split('|')[1:-1]]
    if len(cells) == len(headers):
        rows.append(dict(zip(headers, cells)))
    elif len(cells) > 0:
        # Pad or truncate
        row = {}
        for j, h in enumerate(headers):
            row[h] = cells[j] if j < len(cells) else ''
        rows.append(row)

if not rows:
    print(f'error: table under \"{section}\" has no data rows', file=sys.stderr)
    sys.exit(1)

if fmt == '--csv':
    writer = csv.DictWriter(sys.stdout, fieldnames=headers)
    writer.writeheader()
    writer.writerows(rows)
else:
    print(json.dumps(rows, indent=2))
"
