#!/usr/bin/env bash
set -euo pipefail

# verify-test-integrity: Check test file checksums against test-manifest.md
#
# Usage:
#   verify-test-integrity <test-manifest.md>
#
# Parses the "## Test File Checksums" table, runs sha256sum on each file,
# compares against recorded values.
#
# Exit codes:
#   0 — all checksums match
#   1 — tampered files detected (prints list)
#   2 — manifest missing or no checksums found

MANIFEST="${1:?Usage: verify-test-integrity <test-manifest.md>}"

if [[ ! -f "$MANIFEST" ]]; then
  echo "error: $MANIFEST not found" >&2
  exit 2
fi

# Extract checksum table rows: | filepath | sha256hash |
# Skip header row and separator row
CHECKSUMS=$(python3 -c "
import re, sys

content = open('$MANIFEST').read()

# Find the Test File Checksums section
match = re.search(r'## Test File Checksums\s*\n(.*?)(\n##|\Z)', content, re.DOTALL)
if not match:
    print('no-checksums', file=sys.stderr)
    sys.exit(2)

table_text = match.group(1)
rows = []
for line in table_text.strip().split('\n'):
    line = line.strip()
    if not line.startswith('|') or '---' in line or 'File' in line and 'SHA256' in line:
        continue
    cells = [c.strip() for c in line.split('|')[1:-1]]
    if len(cells) >= 2 and cells[0] and cells[1]:
        # Clean backticks from paths
        path = cells[0].strip('\`')
        sha = cells[1].strip('\`')
        print(f'{sha}  {path}')

if not rows and not table_text.strip():
    sys.exit(2)
" 2>/dev/null) || {
  echo "error: no checksum table found in $MANIFEST"
  exit 2
}

if [[ -z "$CHECKSUMS" ]]; then
  echo "error: no checksum entries found in $MANIFEST"
  exit 2
fi

TAMPERED=()
CHECKED=0

while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  expected_sha=$(echo "$line" | awk '{print $1}')
  filepath=$(echo "$line" | awk '{print $2}')

  if [[ ! -f "$filepath" ]]; then
    TAMPERED+=("$filepath (file missing)")
    ((CHECKED++))
    continue
  fi

  # Use shasum on macOS, sha256sum on Linux
  if command -v sha256sum &>/dev/null; then
    actual_sha=$(sha256sum "$filepath" | awk '{print $1}')
  elif command -v shasum &>/dev/null; then
    actual_sha=$(shasum -a 256 "$filepath" | awk '{print $1}')
  else
    echo "error: no sha256sum or shasum available" >&2
    exit 2
  fi

  if [[ "$actual_sha" != "$expected_sha" ]]; then
    TAMPERED+=("$filepath (expected: ${expected_sha:0:12}... got: ${actual_sha:0:12}...)")
  fi
  ((CHECKED++))
done <<< "$CHECKSUMS"

if [[ ${#TAMPERED[@]} -gt 0 ]]; then
  echo "TAMPERED: ${#TAMPERED[@]} of $CHECKED files modified"
  for f in "${TAMPERED[@]}"; do
    echo "  - $f"
  done
  exit 1
else
  echo "ok: $CHECKED files verified"
  exit 0
fi
