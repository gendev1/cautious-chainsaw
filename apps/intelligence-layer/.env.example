# ──────────────────────────────────────────────────────────────
# Intelligence Layer (Python Sidecar) — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in your values.
# All variables are prefixed with SIDECAR_ in the app config.

# ── General ───────────────────────────────────────────────────
SIDECAR_ENVIRONMENT=development        # development | staging | production
SIDECAR_DEBUG=false
SIDECAR_LOG_LEVEL=INFO
SIDECAR_CORS_ALLOWED_ORIGINS=*         # comma-separated origins

# ── Platform API ──────────────────────────────────────────────
SIDECAR_PLATFORM_API_URL=http://localhost:3000
SIDECAR_PLATFORM_API_KEY=              # service JWT or shared secret
SIDECAR_PLATFORM_API_TIMEOUT_S=30.0

# ── LLM Providers ────────────────────────────────────────────
SIDECAR_ANTHROPIC_API_KEY=             # agents (default provider for all tiers)
SIDECAR_OPENAI_API_KEY=                # embeddings (text-embedding-3-small) + copilot fallback
SIDECAR_TOGETHER_API_KEY=              # optional: Llama 3.3 70B fallback for batch agents
SIDECAR_GROQ_API_KEY=                  # optional
# Note: You need at least one LLM key (Anthropic OR OpenAI).
# OpenAI is also used for embeddings if RAG is enabled.

# ── Model Tiers (override defaults if needed) ────────────────
# SIDECAR_COPILOT_MODEL=anthropic:claude-sonnet-4-6
# SIDECAR_COPILOT_FALLBACK_MODEL=openai:gpt-4o
# SIDECAR_BATCH_MODEL=anthropic:claude-haiku-4-5
# SIDECAR_ANALYSIS_MODEL=anthropic:claude-opus-4-6
# SIDECAR_EXTRACTION_MODEL=anthropic:claude-haiku-4-5
# SIDECAR_EMBEDDING_MODEL=openai:text-embedding-3-small

# ── Redis ─────────────────────────────────────────────────────
SIDECAR_REDIS_URL=redis://localhost:6379/0
SIDECAR_REDIS_MAX_CONNECTIONS=20

# ── ARQ Worker ────────────────────────────────────────────────
# SIDECAR_ARQ_QUEUE_NAME=sidecar:queue
# SIDECAR_ARQ_MAX_JOBS=10
# SIDECAR_ARQ_JOB_TIMEOUT_S=600
# SIDECAR_ARQ_RETRY_COUNT=3

# ── Vector Store (pgvector) ───────────────────────────────────
SIDECAR_VECTOR_STORE_PROVIDER=pgvector # pgvector | qdrant
SIDECAR_VECTOR_STORE_URL=postgresql+asyncpg://localhost:5432/sidecar_vectors
SIDECAR_VECTOR_STORE_COLLECTION=documents
# SIDECAR_VECTOR_SEARCH_TOP_K=20
# SIDECAR_VECTOR_RERANK_TOP_K=8

# ── Transcription ─────────────────────────────────────────────
SIDECAR_TRANSCRIPTION_PROVIDER=whisper # whisper | deepgram
SIDECAR_DEEPGRAM_API_KEY=             # required if using deepgram
# SIDECAR_WHISPER_MODEL=whisper-1
# SIDECAR_MAX_AUDIO_DURATION_S=7200

# ── Langfuse Observability ────────────────────────────────────
SIDECAR_LANGFUSE_ENABLED=true
SIDECAR_LANGFUSE_PUBLIC_KEY=
SIDECAR_LANGFUSE_SECRET_KEY=
SIDECAR_LANGFUSE_HOST=https://us.cloud.langfuse.com

# Langfuse SDK also reads these directly (without SIDECAR_ prefix):
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Conversation Memory ──────────────────────────────────────
# SIDECAR_CONVERSATION_TTL_S=7200       # 2 hours
# SIDECAR_CONVERSATION_MAX_MESSAGES=50

# ── Token Budget ──────────────────────────────────────────────
# SIDECAR_TOKEN_BUDGET_REDIS_PREFIX=sidecar:token_budget
# SIDECAR_DEFAULT_DAILY_TOKEN_LIMIT=2000000

# ── Cache TTLs ────────────────────────────────────────────────
# SIDECAR_STYLE_PROFILE_TTL_S=604800   # 7 days
# SIDECAR_DIGEST_CACHE_TTL_S=86400     # 1 day
